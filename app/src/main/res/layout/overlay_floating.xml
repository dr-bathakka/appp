<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed orb -->
    <ImageView
        android:id="@+id/orbCollapsed"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="#CC0096C7"
        android:padding="12dp"
        android:visibility="visible"/>

    <!-- Expanded panel -->
    <LinearLayout
        android:id="@+id/panelExpanded"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE1A1A2E"
        android:padding="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/inputOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ask CluKey..."
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:background="#33FFFFFF"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/txtOverlayResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#06D6A0"
            android:padding="8dp"
            android:minHeight="40dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOverlaySend"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send"
                android:backgroundTint="#0096C7"/>

            <Button
                android:id="@+id/btnClosePanel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Close"
                android:backgroundTint="#334155"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
