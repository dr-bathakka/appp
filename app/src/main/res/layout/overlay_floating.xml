<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ── COLLAPSED ORB ───────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/orbCollapsed"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:text="⬡"
        android:textSize="28sp"
        android:textColor="#00C8FF"
        android:gravity="center"
        android:background="@drawable/bg_orb"
        android:elevation="8dp"/>

    <!-- ── EXPANDED PANEL ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/panelExpanded"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel_rounded"
        android:elevation="16dp"
        android:visibility="gone"
        android:padding="0dp">

        <!-- Title bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="#0D1117"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">
            <TextView
                android:text="⬡ CLUKEY"
                android:textColor="#00C8FF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/btnClosePanel"
                android:text="×"
                android:textColor="#5A7080"
                android:textSize="20sp"
                android:padding="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Response area -->
        <TextView
            android:id="@+id/txtOverlayResponse"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:padding="12dp"
            android:text="Ask me anything…"
            android:textColor="#E2EAF2"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="top"
            android:background="#080C10"/>

        <!-- Input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#0D1117">
            <EditText
                android:id="@+id/inputOverlay"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input"
                android:textColor="#E2EAF2"
                android:textColorHint="#5A7080"
                android:hint="Type command…"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:paddingHorizontal="8dp"
                android:singleLine="true"/>
            <Button
                android:id="@+id/btnOverlaySend"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:text="➤"
                android:textColor="#080C10"
                android:backgroundTint="#00C8FF"
                android:textSize="13sp"
                android:padding="0dp"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
